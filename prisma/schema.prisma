generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model Habit {
  id          String   @id @default(cuid())
  title       String
  created_at  DateTime @default(now())
  color       String
  isActive    Boolean
  activeDays  String[]
  icon        String
  hour        String
  entries     Entry[]
}

model Entry {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  @@unique([habitId, date])
}
